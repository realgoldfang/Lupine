{
  "appId": "dev.cybernate.lupine",
  "productName": "Lupine",
  "copyright": "Copyright © 2026 Nathan Stallings",
  "publish": {
    "provider": "github",
    "owner": "realgoldfang",
    "repo": "Lupine"
  },
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "dist-electron/**/*"
  ],
  "win": {
    "target": ["nsis", "portable"],
    "icon": "public/icon.ico",
    "publisherName": "Nathan Stallings"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "installerIcon": "public/icon.ico",
    "uninstallerIcon": "public/icon.ico"
  },
  "mac": {
    "target": ["dmg"],
    "icon": "public/icon.icns",
    "identity": null
  },
  "dmg": {
    "contents": [
      { "x": 130, "y": 220 },
      { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
    ]
  },
  "linux": {
    "target": ["AppImage", "deb", "rpm", "snap"],
    "icon": "public/icon.png",
    "category": "Audio",
    "synopsis": "Lupine - Podcast 2.0 Desktop Player",
    "description": "Full-featured podcast player with Podcast 2.0 namespace support including chapters, transcripts, and Value for Value.",
    "maintainer": "Nathan Stallings",
    "executableArgs": ["--no-sandbox"]
  },
  "deb": {
    "maintainer": "Nathan Stallings"
  },
  "rpm": {
    "vendor": "Nathan Stallings"
  },
  "snap": {
    "grade": "stable",
    "confinement": "strict",
    "summary": "Lupine - Podcast 2.0 Desktop Player",
    "plugs": [
      "default",
      "audio-playback",
      "network",
      "network-bind",
      "removable-media"
    ]
  }
}
