{
  "appId": "dev.cybernate.lupine",
  "productName": "Lupine",
  "copyright": "Copyright © 2026 Nathan Stallings",
  "publish": {
    "provider": "github",
    "owner": "realgoldfang",
    "repo": "Lupine"
  },
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "dist-electron/**/*"
  ],
  "win": {
    "target": ["nsis", "portable"],
    "icon": "public/icon.ico",
    "publisherName": "Nathan Stallings"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "installerIcon": "public/icon.ico",
    "uninstallerIcon": "public/icon.ico"
  },
  "linux": {
    "target": ["AppImage", "deb", "rpm", "snap", "flatpak"],
    "icon": "public/icon.png",
    "category": "Audio",
    "synopsis": "Lupine - Podcast 2.0 Desktop Player",
    "description": "Full-featured podcast player with Podcast 2.0 namespace support including chapters, transcripts, and Value for Value.",
    "maintainer": "Nathan Stallings"
  },
  "deb": {
    "maintainer": "Nathan Stallings"
  },
  "rpm": {
    "vendor": "Nathan Stallings"
  },
  "snap": {
    "grade": "stable",
    "confinement": "strict",
    "summary": "Lupine - Podcast 2.0 Desktop Player",
    "plugs": [
      "default",
      "audio-playback",
      "network",
      "network-bind",
      "removable-media"
    ]
  },
  "flatpak": {
    "runtime": "org.freedesktop.Platform",
    "runtimeVersion": "23.08",
    "sdk": "org.freedesktop.Sdk",
    "base": "org.electronjs.Electron2.BaseApp",
    "baseVersion": "23.08",
    "finishArgs": [
      "--share=ipc",
      "--socket=x11",
      "--socket=pulseaudio",
      "--share=network",
      "--device=dri",
      "--talk-name=org.freedesktop.secrets"
    ]
  }
}
